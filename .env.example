# GEMINI_API_KEY: Required for Gemini AI API calls (if applicable).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# --- RELATIONAL DATABASES (POSTGRESQL) CONFIGS ---
# Non-Admin/Pool connection configs for general server operations
SQL_HOST="127.0.0.1"
SQL_USER="inventory_user"
SQL_PASSWORD="secure_user_password"
SQL_DB_NAME="inventory_db"

# Admin connection configs for schema migration tool (Drizzle Kit)
SQL_ADMIN_USER="postgres"
SQL_ADMIN_PASSWORD="secure_postgres_password"
